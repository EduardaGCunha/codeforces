void solve(){
    int n, m; cin >> n >> m;
    vector<pair<int, int>> val(n);
    for(int i = 0; i < n; i++){
        cin >> val[i].second >> val[i].first; // {energia, reatividade}
    }
    
    // Ordena por reatividade decrescente
    sort(val.rbegin(), val.rend());

    // Min-heap para manter as maiores energias e descartar as menores
    priority_queue<int, vector<int>, greater<int>> pq;
    vector<int> ans(n + 1, 0);
    int current_sum = 0;
    int mx_base = 0;
    int idx = 0;

    // i representa o limite de reatividade (e o tamanho do conjunto extra)
    for(int i = n; i >= 0; i--){
        // 1. Adiciona todas as partículas com reatividade >= i
        while(idx < n && val[idx].first >= i){
            current_sum += val[idx].second;
            pq.push(val[idx].second);
            idx++;
        }

        // 2. Se temos mais que i partículas, removemos a menor
        while(pq.size() > i){
            current_sum -= pq.top();
            pq.pop();
        }

        // Se o conjunto tem tamanho K e todos tem reatividade >= K-1, 
        // ele é válido para o caso base (sem a loja)
        // O caso i aqui representa que podemos pegar i partículas da mochila
        // que suportam estar em um grupo de tamanho i+1 (contando a da loja)
        ans[i] = current_sum;

        // Caso base: se todas as i partículas no PQ têm reatividade >= i-1, 
        // a soma delas é um candidato para mx_base. 
        // Como o loop é decrescente, no passo i, todas no PQ têm reatividade >= i.
        // Então elas certamente suportam um grupo de tamanho i.
        mx_base = max(mx_base, current_sum);
    }

    // Prefixo máximo: se a loja permite reatividade 5, posso usar de 0 a 5 partículas.
    for(int i = 1; i <= n; i++) ans[i] = max(ans[i], ans[i-1]);

    while(m--){
        int x, y; cin >> x >> y;
        // Resposta: melhor entre não usar a loja ou usar a loja + y partículas
        cout << max(mx_base, x + ans[y]) << " ";
    }
    cout << endl;
}